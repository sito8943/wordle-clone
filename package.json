{
  "name": "wordle",
  "private": true,
  "version": "0.0.11",
  "type": "module",
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-depcheck",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "prettier": "prettier --write .",
    "lint-depcheck": "depcheck .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:seed-es": "node scripts/seed-spanish-words.mjs",
    "firebase:deploy": "firebase deploy --only hosting:sito-wordle"
  },
  "dependencies": {
    "@fontsource-variable/roboto": "^5.2.10",
    "@fontsource-variable/roboto-slab": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-slab": "^5.2.8",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "convex": "^1.32.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.19",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.5.8",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
